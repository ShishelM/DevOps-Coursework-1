<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TechStore — {{ ansible_hostname }}</title>
    <style>
        /* Общие настройки страницы */
        body { 
            font-family: 'Segoe UI', Tahoma, sans-serif; 
            margin: 0; padding: 0; 
            background: #f0f2f5; 
            display: flex; flex-direction: column; min-height: 100vh; 
        }

        /* Темная плашка наверху */
        nav { 
            background: #1a252f; padding: 10px 30px; 
            display: flex; justify-content: space-between; align-items: center; 
            color: white; 
        }
        nav a { color: white; text-decoration: none; font-weight: bold; font-size: 1.2rem; }
        .node-info { font-size: 0.85rem; color: #bdc3c7; }

        /* Большой заголовок */
        header { 
            background: #2c3e50; color: white; 
            padding: 40px 20px; text-align: center; 
        }
        header h1 { margin: 0; font-size: 2.2rem; }
        header p { margin: 10px 0 0; opacity: 0.8; font-size: 1.1rem; }

        /* Контейнер для товаров */
        .container { 
            max-width: 1200px; 
            margin: 0 auto; 
            padding: 40px 20px; 
            flex: 1;
            width: 100%;
            box-sizing: border-box;
        }

        /* Сетка, которая выстраивает товары в ряд */
        .product-row { 
            display: flex; 
            flex-direction: row; /* ТОВАРИ В РЯД */
            flex-wrap: wrap;     /* Если совсем тесно, перенесет на новую строку */
            justify-content: center; /* Центрируем карточки */
            gap: 25px; 
        }

        /* Карточка товара */
        .card { 
            background: white; 
            border-radius: 12px; 
            box-shadow: 0 4px 15px rgba(0,0,0,0.1); 
            width: 300px; /* Фиксированная ширина, чтобы не сжимались сильно */
            overflow: hidden;
            display: flex; flex-direction: column;
            text-align: center;
            transition: 0.3s;
        }
        .card:hover { transform: translateY(-5px); box-shadow: 0 8px 25px rgba(0,0,0,0.15); }

        .card-img { 
            height: 160px; background: #f8f9fa; 
            display: flex; align-items: center; justify-content: center; 
            font-size: 70px; border-bottom: 1px solid #eee;
        }
        .card-content { padding: 20px; flex-grow: 1; }
        .card-content h3 { margin: 0 0 10px; color: #2c3e50; }
        
        .price { 
            font-size: 1.6rem; color: #27ae60; 
            font-weight: bold; margin: 15px 0; 
        }

        .btn { 
            background: #27ae60; color: white; border: none;
            padding: 12px; border-radius: 8px; width: 100%;
            font-weight: bold; cursor: pointer; font-size: 1rem;
        }
        .btn:hover { background: #219150; }

        /* Футер */
        footer { 
            text-align: center; padding: 25px; 
            background: #2c3e50; color: #bdc3c7; 
            margin-top: 40px;
        }
    </style>
</head>
<body>

    <nav>
        <a href="#">TechStore</a>
        <div class="node-info">
            Host: <strong>{{ ansible_hostname }}</strong> | IP: {{ ansible_default_ipv4.address }}
        </div>
    </nav>

    <header>
        <h1>Лучшие гаджеты здесь</h1>
        <p>Инфраструктура проекта: {{ ansible_hostname }}</p>
    </header>

    <div class="container">
        <div class="product-row">
            
            <!-- Смартфон -->
            <div class="card">
                <div class="card-img">📱</div>
                <div class="card-content">
                    <h3>Смартфон X-Pro</h3>
                    <div class="price">59 990 ₽</div>
                    <button class="btn">В корзину</button>
                </div>
            </div>

            <!-- Ноутбук -->
            <div class="card">
                <div class="card-img">💻</div>
                <div class="card-content">
                    <h3>Ноутбук Air 13</h3>
                    <div class="price">84 500 ₽</div>
                    <button class="btn">В корзину</button>
                </div>
            </div>

            <!-- Наушники -->
            <div class="card">
                <div class="card-img">🎧</div>
                <div class="card-content">
                    <h3>Наушники Noise-Free</h3>
                    <div class="price">12 000 ₽</div>
                    <button class="btn">В корзину</button>
                </div>
            </div>

        </div>
    </div>

    <footer>
        <p>&copy; 2026 Netology CourseWork. Развернуто в Ansible (Node: {{ ansible_hostname }})</p>
    </footer>

</body>
</html>